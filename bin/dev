#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
roles_dir="$repo_root/roles"
venv="$repo_root/.ansible/venv"

PC="${PRECOMMIT_BIN:-$venv/bin/pre-commit}"
[[ -x "$PC" ]] || { echo "ERROR: $PC not found; run 'make install'"; exit 1; }

run_precommit() {
  local dir="$1"; shift
  echo "Running pre-commit in '$dir' with args: $*"
  ( cd "$dir" && "$PC" "$@" )
}

cmd="${1:-}"; sub="${2:-}"; scope="${3:-}"

case "$cmd:$sub" in
    precommit:install)
        run_precommit "$repo_root" install --hook-type pre-commit
        run_precommit "$repo_root" install --hook-type commit-msg
    ;;
    precommit:run)
        run_precommit "$repo_root" run --all-files --hook-stage manual
    ;;
    precommit:autoupdate)
        run_precommit "$repo_root" autoupdate
    ;;
    precommit-role:install)
        [ -n "$scope" ] || { echo "role name required"; exit 1; }
        run_precommit "$roles_dir/$scope" install --hook-type pre-commit
        run_precommit "$roles_dir/$scope" install --hook-type commit-msg
    ;;
    precommit-role:run)
        [ -n "$scope" ] || { echo "role name required"; exit 1; }
        run_precommit "$roles_dir/$scope" run --all-files --hook-stage manual
    ;;
    precommit-role:autoupdate)
        [ -n "$scope" ] || { echo "role name required"; exit 1; }
        run_precommit "$roles_dir/$scope" autoupdate
    ;;
    *)
        echo "usage: bin/dev precommit install|run|autoupdate"
        echo "       bin/dev precommit-role install|run|autoupdate <role>"
        exit 1
    ;;
esac
